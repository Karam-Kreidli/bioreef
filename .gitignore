# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# Virtual envs
.venv/
venv/
env/

# Model weights / checkpoints (too big for git; release separately)
*.pt
*.pth
*.ckpt
weights/

# Run outputs (root-anchored so 'runs/' never matches configs/runs/, which holds
# the experiment CONFIGS and must be tracked).
eval_out/
/outputs/
/runs/
wandb/
*.log

# Per-run metrics.json under results/ ARE committed (the paper's evidence); only
# checkpoints are excluded, via the *.pt/*.pth rules above.

# Data — frames and metadata are large / not redistributable here.
# The released benchmark ships the SPLIT FILE (splits/*.csv), not the images.
# Root-anchored (leading /) so these never match the bioreef/data/ PACKAGE.
/data/
/data_oz/
/frames/
*.csv
!splits/*.csv
# The actual layout is repo-root data/{frames,metadata}/ — already covered by
# the /data/ rule above. bioreef/data/ is the Python PACKAGE and must stay
# tracked, which is exactly why these rules are root-anchored.

# MATANet bridge output — generated on the VM (COCO JSONs with machine-specific
# absolute paths + the exported config). Regenerated by matanet/export_ozfish.py.
matanet/ozfish_data/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
